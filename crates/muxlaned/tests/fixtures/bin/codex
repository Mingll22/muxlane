#!/bin/sh
set -eu

case "${MUXLANE_TEST_CODEX_MODE:-exit}" in
  exit)
    exit 0
    ;;
  error)
    exit 17
    ;;
  refresh)
    temporary="${CODEX_HOME}/.fixture-auth.tmp"
    printf '%s\n' '{"fixture_version":2,"identity":"synthetic-refreshed"}' > "$temporary"
    chmod 600 "$temporary"
    mv "$temporary" "${CODEX_HOME}/auth.json"
    exit 0
    ;;
  wait)
    trap 'exit 130' INT TERM HUP
    while :; do sleep 1; done
    ;;
  *)
    exit 64
    ;;
esac
